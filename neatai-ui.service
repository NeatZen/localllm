# Copy to /etc/systemd/system/neatai-ui.service
# Edit User, WorkingDirectory, and ExecStart paths to match your setup
[Unit]
Description=NeatAi UI
After=network.target

[Service]
Type=simple
# CHANGE THESE to match your user and install path:
User=YOURUSER
WorkingDirectory=/home/YOURUSER/neatai-ui
ExecStart=/home/YOURUSER/neatai-ui/venv/bin/uvicorn app:app --port 8000 --host 0.0.0.0
Restart=always
RestartSec=3
EnvironmentFile=-/home/YOURUSER/neatai-ui/.env

[Install]
WantedBy=multi-user.target
